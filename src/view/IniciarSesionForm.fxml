<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="panelFormIniciarSesion" alignment="CENTER" prefHeight="411.0" prefWidth="482.0" style="-fx-background-color: #0f1115;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.IniciarSesionFormController">
    <children>
        <Label style="-fx-text-fill: #e0e0e0;" text="Iniciar Sesión">
            <font>
                <Font name="System Bold" size="30.0" />
            </font>
        </Label>
        <VBox>
            <VBox.margin>
                <Insets left="50.0" right="50.0" />
            </VBox.margin>
            <children>
                <Label style="-fx-text-fill: #FFFFFF;" text="Usuario">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <TextField fx:id="txtUsuarioIniciarSesion" prefHeight="37.0" promptText="Ej. Usuario" style="-fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-prompt-text-fill: #FFFFFF; -fx-border-color: #76ff03; -fx-border-radius: 5;">
                </TextField>
                <Label style="-fx-text-fill: #FFFFFF;" text="Contraseña">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <StackPane>
                    <children>
                        <PasswordField fx:id="txtContraseñaInicio" prefHeight="37.0" promptText="Ej. 1234" style="-fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-prompt-text-fill: #FFFFFF; -fx-border-color: #76ff03; -fx-border-radius: 5;" />
                        <TextField fx:id="txtContraseñaInicioMask" prefHeight="37.0" promptText="Ej. 1234" style=" -fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-border-color: #76ff03; -fx-border-radius: 5;" visible="false" />
                    </children>
                </StackPane>
                <CheckBox fx:id="checkVerContraseñaInicio" style="-fx-text-fill: #FFFFFF;" text="Ver Contraseña">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </CheckBox>
                <HBox alignment="CENTER">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                    <children>
                        <Button fx:id="btnIngresarInicioS" prefHeight="35.0" prefWidth="100.0" style=" -fx-background-color: #76ff03; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, #76ff03, 10, 0.5, 0, 0);" text="Ingresar" />
                        <Button fx:id="btnLimpiarInicioS" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-border-color: #76ff03; -fx-text-fill: #76ff03; -fx-border-radius: 5;" text="Limpiar">
                            <HBox.margin>
                                <Insets left="10.0" />
                            </HBox.margin>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
