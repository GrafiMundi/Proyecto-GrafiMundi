<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="panelFormRegistro" alignment="CENTER" prefHeight="474.0" prefWidth="700.0" style="-fx-background-color: #0f1115;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RegistrarseFormController">
    <children>
        <Label style="-fx-text-fill: #e0e0e0;" text="Formulario de Registro">
            <font>
                <Font name="System Bold" size="30.0" />
            </font>
        </Label>
        <VBox>
            <children>
                <Label style="-fx-text-fill: #FFFFFF;" text="Correo Electronico">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
                </Label>
                <TextField fx:id="txtEmailRegistro" prefHeight="35.0" promptText="Ej. Usuario@gmail.com" style="-fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-prompt-text-fill: #FFFFFF; -fx-border-color: #76ff03; -fx-border-radius: 5;" />
                <Label style="-fx-text-fill: #FFFFFF;" text="Usuario">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
                </Label>
                <TextField fx:id="txtUsuarioRegistro" prefHeight="35.0" promptText="Ej. Usuario" style="-fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-prompt-text-fill: #FFFFFF; -fx-border-color: #76ff03; -fx-border-radius: 5;" />
                <HBox>
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #FFFFFF;" text="Contraseña">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font></Label>
                                <StackPane>
                                    <children>
                                        <PasswordField fx:id="txtContraseñaRegistro" prefHeight="35.0" style="-fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-border-color: #76ff03; -fx-border-radius: 5;" />
                                        <TextField fx:id="txtContraseñaRegistroMask" prefHeight="35.0" style=" -fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-border-color: #76ff03; -fx-border-radius: 5;" visible="false" />
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #FFFFFF;" text="Confirmar Contraseña">
                                    <VBox.margin>
                                        <Insets left="10.0" />
                                    </VBox.margin>
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                                </Label>
                                <StackPane>
                                    <VBox.margin>
                                        <Insets left="10.0" />
                                    </VBox.margin>
                                    <children>
                                        <PasswordField fx:id="txtConfirmarContraRegistro" prefHeight="35.0" style=" -fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-border-color: #76ff03; -fx-border-radius: 5;" />
                                        <TextField fx:id="txtConfirmarContraRegistroMask" prefHeight="35.0" style="-fx-background-color: #1a1d23; -fx-text-fill: #e0e0e0; -fx-border-color: #76ff03; -fx-border-radius: 5;" visible="false" />
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>
                <CheckBox fx:id="checkVerContraseñaRegistro" style="-fx-text-fill: #FFFFFF;" text="Mostrar contraseña">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </CheckBox>
                <HBox alignment="CENTER">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                    <children>
                        <Button fx:id="btnRegistrarse" prefHeight="35.0" prefWidth="120.0" style=" -fx-background-color: #76ff03; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, #76ff03, 10, 0.5, 0, 0);" text="Registrarse" />
                        <Button fx:id="btnLimpiarRegistrarse" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-border-color: #76ff03; -fx-text-fill: #76ff03; -fx-border-radius: 5;" text="Limpiar">
                            <HBox.margin>
                                <Insets left="10.0" />
                            </HBox.margin>
                        </Button>
                    </children>
                </HBox>
            </children>
            <VBox.margin>
                <Insets left="40.0" right="40.0" />
            </VBox.margin>
        </VBox>
    </children>
</VBox>
